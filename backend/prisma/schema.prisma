// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum ElementType {
  API
  AIR
  ANGIN
  TANAH
}

// ============================================================
// MODELS
// ============================================================

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String
  googleId     String?        @unique
  password     String?        // null jika login via Google
  isAdmin      Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  testResults  TestResult[]
  voucherClaim VoucherClaim?  // 1 user = 1 voucher seumur hidup

  @@map("users")
}

model Question {
  id        String         @id @default(uuid())
  text      String         @db.Text
  element   ElementType    // Label elemen untuk pengacakan 5-5-5-5
  isActive  Boolean        @default(true)
  options   AnswerOption[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([element, isActive]) // Untuk query SELECT 5 soal per elemen
  @@map("questions")
}

model AnswerOption {
  id         String      @id @default(uuid())
  questionId String
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  targetType ElementType // Elemen yang mendapat +1 jika opsi ini dipilih
  order      Int         @default(0) // Urutan tampil di frontend

  @@index([questionId])   // Foreign key index
  @@map("answer_options")
}

model TestResult {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Skor per elemen (dari 20 soal kepribadian)
  scoreApi        Int         @default(0)
  scoreAir        Int         @default(0)
  scoreAngin      Int         @default(0)
  scoreTanah      Int         @default(0)

  // Hasil persona
  personaPrimer   ElementType
  personaSekunder ElementType

  // Jawaban soal penutup (survei)
  surveySource    String      // "Dari mana tahu Vundiego?"
  surveyRelate    String?     // "Apakah hasilnya relate?"

  // Feedback opsional dari user
  feedbackRating  Int?        // 1-5
  feedbackText    String?     @db.Text

  // Token untuk akses rapot via link email (berlaku 30 hari)
  reportToken     String      @unique
  reportTokenExp  DateTime

  createdAt       DateTime    @default(now())

  @@index([userId])            // Foreign key index
  @@index([personaPrimer])     // Untuk query elemen dominan di homepage
  @@map("test_results")
}

model SystemMetric {
  id               Int @id @default(1) // Selalu hanya 1 baris
  manualSalesCount Int @default(0)     // Diupdate manual oleh admin
  totalVisitors    Int @default(0)     // Diincrement setiap kunjungan

  @@map("system_metrics")
}

model ReportTemplate {
  id               ElementType @id // API / AIR / ANGIN / TANAH

  // Info parfum
  parfumName       String      // Choleric / Melancholic / Sanguine / Phlegmatic

  // Deskripsi persona (editable oleh admin)
  description      String      @default("") @db.Text  // Deskripsi singkat persona
  descriptionPlus  String      @db.Text
  descriptionMinus String      @db.Text

  // Rekomendasi & tagline parfum
  parfumRecommendation String  @default("")  // Nama parfum yang direkomendasikan
  parfumTagline        String  @default("")  // Tagline/deskripsi singkat parfum

  // Aset visual (URL dari Supabase Storage)
  backgroundImage  String      @default("")

  // Link toko e-commerce
  shopeeLink       String?
  tiktokLink       String?
  instagramLink    String?

  updatedAt        DateTime    @updatedAt

  @@map("report_templates")
}

// ─── Voucher System ─────────────────────────────────────────

model VoucherConfig {
  id              Int      @id @default(1)     // Selalu 1 baris
  isEnabled       Boolean  @default(false)     // Toggle ON/OFF global
  voucherCode     String   @default("")        // Kode voucher Shopee
  discountLabel   String   @default("Potongan Rp4.000")
  totalStock      Int      @default(0)         // Stok total voucher
  claimedCount    Int      @default(0)         // Jumlah sudah di-claim
  expiryHours     Int      @default(72)        // Masa berlaku per user (3 hari)
  shopeeUrl       String   @default("https://shopee.co.id/vundiego?categoryId=100630&entryPoint=ShopByPDP&itemId=51311595656&upstream=search")
  updatedAt       DateTime @updatedAt

  @@map("voucher_config")
}

model VoucherClaim {
  id          String   @id @default(uuid())
  userId      String   @unique               // 1 user = 1 claim seumur hidup
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucherCode String                          // Snapshot kode saat di-claim
  claimedAt   DateTime @default(now())
  expiresAt   DateTime                        // claimedAt + expiryHours

  @@map("voucher_claims")
}

