# ============================================================
#  BACKEND — Environment Variables
#  Website Tes 4 Persona Vundiego
#  Salin file ini menjadi .env dan isi nilainya
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# --- Database (PostgreSQL via Neon.tech atau Supabase) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# --- JWT ---
JWT_SECRET=ganti_dengan_secret_yang_kuat_dan_panjang
JWT_EXPIRY=7d

# --- Google OAuth2 ---
# Dapatkan dari: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- Brevo (Email Service) ---
# Dapatkan API Key dari: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=noreply@vundiego.com
BREVO_FROM_NAME=4Persona Vundiego

# --- Supabase Storage ---
# Dapatkan dari: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=report-assets

# --- Report Token ---
REPORT_TOKEN_EXPIRY_DAYS=30
